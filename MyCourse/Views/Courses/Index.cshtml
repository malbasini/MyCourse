@model List<CourseViewModel>

<h1>@ViewData["Title"]</h1>
@foreach (CourseViewModel course in Model)
{
<hr>
<div class="row">
    <div class="col-md-1">
        <img src = @course.ImagePath width="70px" height="30px">
    </div>
    <div class="col-md-5">
        <h2>@course.Title</h2>
        <author class="author">@course.Author</author>
    </div>
    <div class="col-md-2 rating">
        @for(int i = 1; i<=5; i++)
        {
            if(course.Rating >=i)
            {
                <i class="fas fa-star"></i>
            }
            else if(course.Rating > i - 1)
            {
                <i class="fas fa-star-half-alt"></i>
            } 
        }
    </div>
    <div class="col-md-2 price" >
       
        @if(course.CurrentPrice.Equals(course.FullPrice))
        {
              @course.FullPrice
        }
        else
        {
              @course.CurrentPrice  <br><s>@course.FullPrice</s>
        }
    </div>
    <div class="col-md-2">
        <a class="btn btn-outline-primary" asp-action="Detail" asp-controller="Courses" asp-route-id=@course.Id>Dettaglio corso</a>
    </div>
</div>
}




    