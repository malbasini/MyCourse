@model List<CourseViewModel>
<div class="row">
    <div class="col-md-8">
        <h1>@ViewData["Title"]</h1>
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <form asp-controller="Courses" asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Cerca..." aria-label="Cerca..." aria-describedby="search-button">
                <div class="input-group-append">
                    <button class="input-group-text" id="search-button"><i class="fas fa-search"></i></button>
                </div>
            </div>
        </form>
    </div>
</div>
@foreach (CourseViewModel course in Model)
{
<hr>
<div class="row">
    <div class="col-md-1">
        <img src = @course.ImagePath width="70px" height="70px">
    </div>
    <div class="col-md-5">
        <h2>@course.Title</h2>
        <author class="author">@course.Author</author>
    </div>
    <div class="col-md-2 rating">
        @for(int i = 1; i<=5; i++)
        {
            if(course.Rating >=i)
            {
                <i class="fas fa-star"></i>
            }
            else if(course.Rating > i - 1)
            {
                <i class="fas fa-star-half-alt"></i>
            } 
            else
            {
                 <i class="far fa-star"></i>
            }
        }
    </div>
    <div class="col-md-2 price" >
       
        @if(course.CurrentPrice.Equals(course.FullPrice))
        {
              @course.FullPrice
        }
        else
        {
              @course.CurrentPrice  <br><s>@course.FullPrice</s>
        }
    </div>
    <div class="col-md-2">
        <a class="btn btn-outline-primary" asp-action="Detail" asp-controller="Courses" asp-route-id=@course.Id>Dettaglio corso</a>
    </div>
</div>
}




    